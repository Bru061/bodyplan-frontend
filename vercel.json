{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://bodyplan-api.giize.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://bodyplan-api.giize.com/uploads/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}